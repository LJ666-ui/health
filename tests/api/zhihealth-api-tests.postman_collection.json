ysis/comprehensive", "host": ["{{baseUrl}}"], "path": ["/api/v1/analysis/comprehensive"]}}}]}, {"name": "4-AI Module", "item": [{"name": "AI Risk Prediction", "event": [{"listen": "test", "script": {"exec": ["pm.test('AI predict response', () => pm.expect(pm.response.code).to.be.oneOf([200, 400, 500]));"], "type": "text/javascript"}}], "request": {"method": "POST", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{ \"records\": [{\"heart_rate\": 75, \"blood_pressure_systolic\": 120, \"blood_pressure_diastolic\": 80, \"user_id\": 1}] }"}, "url": {"raw": "{{baseUrl}}/api/v1/ai/predict", "host": ["{{baseUrl}}"], "path": ["/api/v1/ai/predict"]}}}, {"name": "AI Trend Analysis", "event": [{"listen": "test", "script": {"exec": ["pm.test('Trend response', () => pm.expect(pm.response.code).to.be.oneOf([200, 400]));"], "type": "text/javascript"}}], "request": {"method": "POST", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{}"}, "url": {"raw": "{{baseUrl}}/api/v1/ai/trend", "host": ["{{baseUrl}}"], "path": ["/api/v1/ai/trend"]}}}, {"name": "AI User Segmentation", "event": [{"listen": "test", "script": {"exec": ["pm.test('Segment response', () => pm.expect(pm.response.code).to.be.oneOf([200, 400]));"], "type": "text/javascript"}}], "request": {"method": "POST", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{}"}, "url": {"raw": "{{baseUrl}}/api/v1/ai/segment", "host": ["{{baseUrl}}"], "path": ["/api/v1/ai/segment"]}}}, {"name": "AI Comprehensive Analysis", "event": [{"listen": "test", "script": {"exec": ["pm.test('AI comprehensive response', () => pm.expect(pm.response.code).to.be.oneOf([200, 400]));"], "type": "text/javascript"}}], "request": {"method": "POST", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{}"}, "url": {"raw": "{{baseUrl}}/api/v1/ai/comprehensive", "host": ["
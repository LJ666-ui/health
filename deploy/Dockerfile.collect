# Collect采集服务
FROM maven:3.9-eclipse-temurin-17 AS builder
WORKDIR /app
COPY zhihealth-cloud/pom.xml .
COPY zhihealth-cloud/zhihealth-collect ./zhihealth-collect
RUN cd zhihealth-collect && mvn clean package -DskipTests

FROM eclipse-temurin:17-jre-alpine
WORKDIR /app
COPY --from=builder /app/zhihealth-collect/target/*.jar app.jar
EXPOSE 8083
ENTRYPOINT ["java", "-jar", "app.jar"]

# Alert预警服务
FROM maven:3.9-eclipse-temurin-17 AS builder
WORKDIR /app
COPY zhihealth-cloud/pom.xml .
COPY zhihealth-cloud/zhihealth-alert ./zhihealth-alert
RUN cd zhihealth-alert && mvn clean package -DskipTests

FROM eclipse-temurin:17-jre-alpine
WORKDIR /app
COPY --from=builder /app/zhihealth-alert/target/*.jar app.jar
EXPOSE 8086
ENTRYPOINT ["java", "-jar", "app.jar"]

# ============================================================
#  智康云枢 环境变量配置模板
#  使用方式: 复制为 .env 后修改实际值
#  cp .env.example .env
# ============================================================

# ---- MySQL ----
MYSQL_ROOT_PASSWORD=123456
MYSQL_HOST=mysql-master
MYSQL_PORT=3306

# ---- Redis ----
REDIS_PASSWORD=redis_2024
REDIS_HOST=redis-master
REDIS_PORT=6379

# ---- InfluxDB ----
INFLUX_PASSWORD=influx_2024

# ---- MongoDB ----
MONGO_PASSWORD=mongo_2024

# ---- RabbitMQ ----
RABBITMQ_PASSWORD=rabbit_2024

# ---- Ollama (大模型) ----
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2:7b

# ---- Nacos ----
NACOS_HOST=nacos1
NACOS_PORT=8848
NACOS_USERNAME=nacos
NACOS_PASSWORD=nacos

# ---- JVM通用参数 ----
JAVA_OPTS=-Xms256m -Xmx512m -XX:+UseG1GC -XX:MaxGCPauseMillis=200

# ---- 时区 ----
TZ=Asia/Shanghai
